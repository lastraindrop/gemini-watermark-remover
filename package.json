{
  "name": "@lastraindrop/gemini-watermark-remover",
  "description": "Automatically removes watermarks from Gemini AI generated images",
  "version": "2.7.0",
  "author": "lastraindrop contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/lastraindrop/gemini-watermark-remover.git"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "src",
    "bin",
    "dist",
    "public",
    "python",
    "LICENSE",
    "README.md",
    "README_zh.md"
  ],
  "bin": {
    "gwr": "./bin/gwr.mjs",
    "gemini-watermark-remover": "./bin/gwr.mjs"
  },
  "types": "./src/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/sdk/index.d.ts",
      "import": "./src/sdk/index.js"
    },
    "./sdk": {
      "types": "./src/sdk/index.d.ts",
      "import": "./src/sdk/index.js"
    }
  },
  "scripts": {
    "dev": "node build.js",
    "build": "node build.js --production",
    "serve": "npx serve dist",
    "test": "node --import ./tests/fixtures/canvas-mock.mjs --loader ./tests/fixtures/png-loader.mjs --test --test-concurrency=4 \"tests/*.test.js\"",
    "test:unit": "node --import ./tests/fixtures/canvas-mock.mjs --loader ./tests/fixtures/png-loader.mjs --test --test-concurrency=4 \"tests/*.test.js\"",
    "test:nocanvas": "node --loader ./tests/fixtures/png-loader.mjs --test --test-concurrency=4 \"tests/*.test.js\"",
    "test:precision": "node --loader ./tests/fixtures/png-loader.mjs --test tests/parameter_matrix.test.js tests/product_audit.test.js tests/e2e_integration.test.js",
    "test:legacy": "node --test \"tests/scripts/v1.5_edge_crop.test.js\" \"tests/scripts/v1.5_noise_reduction.test.js\"",
    "test:all": "node --test --test-concurrency=4 \"tests/*.test.js\" \"tests/scripts/v1.5_edge_crop.test.js\" \"tests/scripts/v1.5_noise_reduction.test.js\"",
    "test:python": "python -m unittest tests\\test_bridge_integration.py",
    "test:worker": "node --loader ./tests/fixtures/png-loader.mjs --test tests/worker_resilience.test.js tests/engine_lifecycle.test.js",
    "test:stress": "node --import ./scripts/stress-env.mjs --test \"tests/memory_pressure.test.js\"",
    "cli": "node src/cli.js",
    "gui": "python python/gui.py",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "jszip": "^3.10.1",
    "medium-zoom": "^1.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "eslint": "^9.1.1",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.19"
  },
  "packageManager": "pnpm@10.11.0"
}
