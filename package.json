{
  "name": "@lastraindrop/gemini-watermark-remover",
  "description": "Local detection, analysis, and removal of visible Gemini and Doubao AI watermarks",
  "version": "2.7.0",
  "author": "lastraindrop contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/lastraindrop/gemini-watermark-remover.git"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "src",
    "bin",
    "dist",
    "public",
    "python",
    "LICENSE",
    "README.md",
    "README_zh.md"
  ],
  "bin": {
    "gwr": "./bin/gwr.mjs",
    "gemini-watermark-remover": "./bin/gwr.mjs"
  },
  "types": "./src/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/sdk/index.d.ts",
      "import": "./src/sdk/index.js"
    },
    "./sdk": {
      "types": "./src/sdk/index.d.ts",
      "import": "./src/sdk/index.js"
    }
  },
  "scripts": {
    "dev": "node build.js",
    "build": "node build.js --production",
    "serve": "npx serve dist",
    "test": "node scripts/test-groups.mjs unit --reporter=dot",
    "test:unit": "node scripts/test-groups.mjs unit --reporter=dot",
    "test:integration": "node scripts/test-groups.mjs integration --reporter=dot",
    "test:precision": "node scripts/test-groups.mjs precision --reporter=dot",
    "test:audit": "node scripts/test-groups.mjs audit --reporter=dot",
    "test:diagnostic": "node scripts/test-groups.mjs diagnostic --reporter=dot",
    "test:nocanvas": "node scripts/test-groups.mjs all --no-canvas-mock --reporter=dot",
    "test:legacy": "node scripts/test-groups.mjs legacy --reporter=dot",
    "test:all": "node scripts/test-groups.mjs all --reporter=dot",
    "test:exhaustive": "node scripts/test-groups.mjs exhaustive --reporter=dot",
    "test:python": "python -m unittest tests\\test_bridge_integration.py",
    "test:worker": "node scripts/test-groups.mjs worker --reporter=dot",
    "test:stress": "node scripts/test-groups.mjs stress --reporter=dot",
    "cli": "node src/cli.js",
    "gui": "python python/gui.py",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "jszip": "^3.10.1",
    "medium-zoom": "^1.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "eslint": "^9.1.1",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.19"
  },
  "packageManager": "pnpm@10.11.0"
}
