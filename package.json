{
  "name": "gemini-watermark-remover",
  "description": "Automatically removes watermarks from Gemini AI generated images",
  "version": "1.0.0",
  "author": "journey-ad",
  "repository": {
    "type": "git",
    "url": "https://github.com/journey-ad/gemini-watermark-remover.git"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "gemini-watermark-remover": "./src/cli.js"
  },
  "scripts": {
    "dev": "node build.js",
    "build": "npx -y cross-env NODE_ENV=production node build.js",
    "serve": "npx serve dist",
    "test": "node --test tests/v1.1_*.test.js tests/v1.2_*.test.js tests/repro_issue.test.js",
    "cli": "node src/cli.js",
    "gui": "python python/gui.py",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "jszip": "^3.10.1",
    "medium-zoom": "^1.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "eslint": "^9.1.1",
    "prettier": "^3.2.5"
  },
  "packageManager": "pnpm@10.11.0"
}
