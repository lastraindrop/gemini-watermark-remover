{
  "name": "@pilio/gemini-watermark-remover",
  "description": "Automatically removes watermarks from Gemini AI generated images",
  "version": "2.1.0",
  "author": "journey-ad",
  "repository": {
    "type": "git",
    "url": "https://github.com/journey-ad/gemini-watermark-remover.git"
  },
  "license": "MIT",
  "type": "module",
  "files": [
    "src",
    "bin",
    "skills",
    "dist",
    "public",
    "python",
    "LICENSE",
    "README.md",
    "README_zh.md"
  ],
  "bin": {
    "gwr": "./bin/gwr.mjs",
    "gemini-watermark-remover": "./bin/gwr.mjs"
  },
  "scripts": {
    "dev": "node build.js",
    "build": "node build.js --production",
    "serve": "npx serve dist",
    "test": "node --test --test-concurrency=4 \"tests/*.test.js\"",
    "test:stress": "node --import ./scripts/stress-env.mjs --test \"tests/memory_pressure.test.js\"",
    "cli": "node src/cli.js",
    "gui": "python python/gui.py",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "jszip": "^3.10.1",
    "medium-zoom": "^1.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "eslint": "^9.1.1",
    "prettier": "^3.2.5"
  },
  "packageManager": "pnpm@10.11.0"
}
